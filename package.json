{
  "name": "supplywatch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @supplywatch/state build && TMPDIR=/tmp tsx src/worker.ts",
    "watcher:dev": "pnpm dev",
    "capture:fixture": "pnpm --filter @supplywatch/state build && TMPDIR=/tmp tsx src/worker.ts capture-fixture",
    "build": "pnpm --filter @supplywatch/state build && tsc -p tsconfig.json",
    "watcher:build": "pnpm build",
    "start": "node dist/worker.js",
    "typecheck": "pnpm --filter @supplywatch/state build && tsc -p tsconfig.json --noEmit",
    "watcher:typecheck": "pnpm typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm --filter @supplywatch/state db:migrate",
    "db:studio": "drizzle-kit studio",
    "test": "pnpm --filter @supplywatch/state build && vitest run",
    "watcher:test": "pnpm test",
    "test:watch": "pnpm --filter @supplywatch/state build && vitest",
    "verify": "concurrently -n typecheck,lint,build,test -c blue,magenta,green,yellow \"pnpm typecheck\" \"pnpm lint\" \"pnpm build\" \"pnpm test\"",
    "watcher:verify": "pnpm verify",
    "playwright:install": "playwright install chromium",
    "sandcastle": "pnpm exec tsx .sandcastle/main.ts",
    "sandcastle:build-image": "sandcastle docker build-image"
  },
  "dependencies": {
    "@supplywatch/state": "workspace:*",
    "better-sqlite3": "^12.4.6",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "playwright": "^1.57.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.6.4",
    "@biomejs/biome": "^2.4.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
