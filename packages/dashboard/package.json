{
  "name": "@supplywatch/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "client:dev": "vite --host 127.0.0.1",
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm server:dev\" \"pnpm client:dev\"",
    "server:dev": "TMPDIR=/tmp tsx watch src/server/main.ts",
    "start": "node dist/server/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@supplywatch/state": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "jsdom": "^27.3.0",
    "tsx": "^4.22.4"
  }
}
